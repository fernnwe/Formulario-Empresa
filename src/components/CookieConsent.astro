<div class="cookie-bar" id="cookieBar" aria-hidden="true">
  <div class="container">
    <div class="cookie-bar-inner">
      <p>Este sitio usa cookies para mejorar tu experiencia.</p>
      <div class="cookie-bar-actions">
        <button class="cookie-btn" id="cookieAccept">Aceptar</button>
        <button class="cookie-link" id="cookieMore">Info</button>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    if (localStorage.getItem("cookie-consent")) return;

    const bar = document.getElementById("cookieBar");
    const accept = document.getElementById("cookieAccept");
    const more = document.getElementById("cookieMore");

    requestAnimationFrame(() => {
      bar.setAttribute("aria-hidden", "false");
      bar.classList.add("visible");
    });

    accept.addEventListener("click", () => {
      localStorage.setItem("cookie-consent", "accepted");
      bar.classList.remove("visible");
      bar.setAttribute("aria-hidden", "true");
      setTimeout(() => bar.remove(), 300);
    });

    more.addEventListener("click", () => {
      alert(
        "Usamos cookies propias y de terceros necesarias para el funcionamiento del sitio. Al navegar aceptás su uso."
      );
    });
  })();
</script>

<style>
  .cookie-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: var(--surface);
    border-top: 1px solid var(--border);
    transform: translateY(100%);
    opacity: 0;
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    transition: background 0.35s ease, border-color 0.35s ease, transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.35s ease;
  }

  .cookie-bar.visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .cookie-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 0;
    flex-wrap: wrap;
  }

  .cookie-bar-inner p {
    font-size: 0.88rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .cookie-bar-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .cookie-btn {
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    padding: 0.5rem 1rem;
    border-radius: 7px;
    background: var(--accent);
    color: #fff;
    transition: all 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .cookie-btn:hover {
    background: var(--accent-hover);
  }

  .cookie-link {
    font-family: inherit;
    font-size: 0.78rem;
    cursor: pointer;
    border: none;
    background: none;
    color: var(--text-tertiary);
    text-decoration: underline;
    text-underline-offset: 2px;
    padding: 0.4rem 0.3rem;
    transition: color 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .cookie-link:hover {
    color: var(--accent);
  }

  @media (max-width: 480px) {
    .cookie-bar-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      padding: 0.75rem 0;
    }

    .cookie-bar-inner p {
      font-size: 0.82rem;
    }
  }
</style>
