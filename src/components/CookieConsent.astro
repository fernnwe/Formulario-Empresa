---
const COOKIE_CONSENT_KEY = "cookie-consent";
---

<div class="cookie-banner" id="cookieBanner" aria-live="polite">
  <div class="cookie-banner-inner">
    <div class="cookie-banner-content">
      <div class="cookie-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"/><path d="M8.5 8.5v.01"/><path d="M16 15.5v.01"/><path d="M12 12v.01"/><path d="M11 17v.01"/><path d="M7 14v.01"/></svg>
      </div>
      <p>Usamos cookies propias y de terceros para mejorar tu experiencia en nuestro sitio web.</p>
    </div>
    <div class="cookie-banner-actions">
      <button class="cookie-btn cookie-btn-primary" id="cookieAccept">Aceptar</button>
      <button class="cookie-btn cookie-btn-link" id="cookieMore">Más información</button>
    </div>
  </div>
</div>

<script>
  (function () {
    const KEY = "cookie-consent";

    if (localStorage.getItem(KEY)) return;

    const banner = document.getElementById("cookieBanner");
    const acceptBtn = document.getElementById("cookieAccept");
    const moreBtn = document.getElementById("cookieMore");

    requestAnimationFrame(() => {
      banner.classList.add("visible");
    });

    function accept() {
      localStorage.setItem(KEY, "accepted");
      banner.classList.remove("visible");
      setTimeout(() => banner.remove(), 400);
    }

    acceptBtn.addEventListener("click", accept);
    moreBtn.addEventListener("click", () => {
      window.open("#", "_blank");
    });
  })();
</script>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    padding: 0 1rem 1rem;
    transform: translateY(100%);
    opacity: 0;
    transition: all 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .cookie-banner.visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .cookie-banner-inner {
    max-width: 640px;
    margin: 0 auto;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow-elevated, 0 8px 30px rgba(0, 0, 0, 0.12));
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: background 0.35s ease, border-color 0.35s ease;
  }

  .cookie-banner-content {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .cookie-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--accent-subtle, rgba(37, 99, 235, 0.1));
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cookie-icon svg {
    width: 18px;
    height: 18px;
  }

  .cookie-banner-content p {
    font-size: 0.84rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .cookie-banner-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-left: 3rem;
  }

  .cookie-btn {
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    padding: 0.5rem 1.1rem;
    border-radius: 8px;
    transition: all 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .cookie-btn-primary {
    background: var(--accent);
    color: #fff;
  }

  .cookie-btn-primary:hover {
    background: var(--accent-hover);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .cookie-btn-link {
    background: transparent;
    color: var(--text-tertiary);
    padding: 0.5rem 0.5rem;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .cookie-btn-link:hover {
    color: var(--accent);
  }

  @media (max-width: 480px) {
    .cookie-banner {
      padding: 0 0.75rem 0.75rem;
    }

    .cookie-banner-inner {
      padding: 1rem;
      border-radius: 12px;
    }

    .cookie-banner-content p {
      font-size: 0.8rem;
    }

    .cookie-banner-actions {
      padding-left: 0;
    }

    .cookie-btn {
      font-size: 0.8rem;
      padding: 0.45rem 0.9rem;
    }
  }
</style>
