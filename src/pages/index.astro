---
import Header from "../components/Header.astro";
import ContactForm from "../components/ContactForm.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Energy Ingeniería — Climatización &amp; Refrigeración Profesional</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />

    <section class="hero">
      <div class="container">
        <span class="hero-badge">Expertos en climatización</span>
        <h1>
          Soluciones de <span>energía</span> y confort<br />
          para tu hogar o industria
        </h1>
        <p>
          Más de 10 años brindando instalación, mantenimiento y venta de equipos
          de climatización, refrigeración y sistemas HVAC en toda Nicaragua.
        </p>
      </div>
    </section>

    <div class="container">
      <div class="services-strip">
        <span class="service-chip">❄️ A/A</span>
        <span class="service-chip">🏠 Residencial</span>
        <span class="service-chip">🏭 Industrial</span>
        <span class="service-chip">🧊 Cuartos Fríos</span>
        <span class="service-chip">⚡ Chiller</span>
        <span class="service-chip">🔧 VRF</span>
        <span class="service-chip">⚙️ Compresores</span>
      </div>
    </div>

    <main class="main">
      <div class="container">
        <div class="main-grid">
          <div class="info-side">
            <div class="info-card">
              <div class="info-card-icon blue">⚡</div>
              <h3>Asesoría técnica especializada</h3>
              <p>Te guiamos en la elección del equipo ideal según tus necesidades y presupuesto.</p>
            </div>
            <div class="info-card">
              <div class="info-card-icon purple">🔧</div>
              <h3>Instalación profesional</h3>
              <p>Instalamos con personal certificado y garantía en todos nuestros trabajos.</p>
            </div>
            <div class="info-card">
              <div class="info-card-icon green">🛡️</div>
              <h3>Soporte post-venta</h3>
              <p>Servicio de mantenimiento preventivo y correctivo para alargar la vida de tus equipos.</p>
            </div>
          </div>
          <ContactForm />
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>
